{
  "name": "ferramentas-postech",
  "version": "0.1.0",
  "author": {
    "name": "Diana Fuchs Santos",
    "email": "diana.fuchs@example.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --x64 --publish never",
    "build:linux": "electron-builder --linux --x64 --publish never",
    "release": "electron-builder --win --mac --linux --x64 --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DyFuchs/Ferramentas_POSTECH_Electron.git"
  },
  "build": {
    "appId": "com.postech.ferramentas",
    "productName": "Ferramentas POSTECH",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "rust-backend/target/release/organizador-postech-backend.exe",
        "to": "backend/organizador-postech-backend.exe"
      },
      {
        "from": "rust-backend/target/release/organizador-postech-backend",
        "to": "backend/organizador-postech-backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publish": [
        {
          "provider": "github",
          "owner": "DyFuchs",
          "repo": "Ferramentas_POSTECH_Electron",
          "releaseType": "release"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "rust-backend/target/release/organizador-postech-backend",
          "to": "backend/organizador-postech-backend"
        }
      ],
      "publish": [
        {
          "provider": "github",
          "owner": "DyFuchs",
          "repo": "Ferramentas_POSTECH_Electron",
          "releaseType": "release"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "extraResources": [
        {
          "from": "rust-backend/target/release/organizador-postech-backend",
          "to": "backend/organizador-postech-backend"
        }
      ],
      "publish": [
        {
          "provider": "github",
          "owner": "DyFuchs",
          "repo": "Ferramentas_POSTECH_Electron",
          "releaseType": "release"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
